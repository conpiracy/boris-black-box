{
  "name": "blackbox",
  "type": "module",
  "private": true,
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "npm run test:node && npm run test:compat",
    "test:node": "vitest run --config vitest.node.config.ts",
    "test:compat": "bun run scripts/compatibility-matrix.ts",
    "dev": "bunx alchemy dev",
    "deploy": "bunx alchemy deploy",
    "destroy": "bunx alchemy destroy",
    "smoke": "bun run scripts/smoke-test.ts"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260401.1",
    "@types/bun": "latest",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "alchemy": "^0.90.1",
    "aws4fetch": "^1.0.20",
    "hono": "^4.12.9",
    "mediabunny": "^1.40.1",
    "ulid": "^3.0.2",
    "zod": "^4.3.6"
  }
}
